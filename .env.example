# .env.example - environment variables for CashMaker V16
# Copy this file to `.env` and fill real values. NEVER commit real secrets to git.

# Gemini (Google) API key for Gemini 3.1
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API key (text-to-speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Facebook / Meta access token for Pages / Instagram Business
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here

# Google Cloud Storage (used by cashmaker-veo-worker)
# Option A: path to service account JSON file on the host/container (recommended)
GOOGLE_CREDENTIALS_PATH=/path/to/service-account.json

# Option B: (alternative) single-line escaped JSON (less recommended)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}

GCS_BUCKET_NAME=your_gcs_bucket_name_here

# cashmaker-veo-worker endpoint (if self-hosted or on Railway/Heroku)
CASHMAKER_VEO_WORKER_URL=https://cashmaker-veo-worker-production.up.railway.app

# Optional tuning values
POLLING_INTERVAL=10
MAX_POLLING_ATTEMPTS=60
REQUEST_TIMEOUT=120
MAX_VIDEO_SIZE_BYTES=524288000
